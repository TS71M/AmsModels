    <Import Project="$(NuGetPackageRoot)magick.net-q16-anycpu\14.13.0\buildTransitive\netstandard20\Magick.NET-Q16-AnyCPU.targets" Condition="Exists('$(NuGetPackageRoot)magick.net-q16-anycpu\14.13.0\buildTransitive\netstandard20\Magick.NET-Q16-AnyCPU.targets')" />
